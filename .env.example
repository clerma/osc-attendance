# --- Frontend (Vite) -------------------------------------------------
# Public Supabase project URL, e.g. https://abcdefg.supabase.co
VITE_SUPABASE_URL=
# Supabase anon (public) key
VITE_SUPABASE_ANON_KEY=
# Base URL of the deployed Worker / serverless function, e.g.
# https://osc-attendance-api.<account>.workers.dev
VITE_API_BASE=

# --- Worker (set via `wrangler secret put`, not committed) -----------
# ANTHROPIC_API_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
